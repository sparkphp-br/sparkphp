# Aplicação
APP_NAME=SparkPHP
APP_ENV=dev
APP_PORT=8000
APP_KEY=change-me-to-a-random-secret-32-chars
APP_LANG=pt-BR
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo

# Banco de dados
DB=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sparkphp
DB_USER=root
DB_PASS=

# Sessão
SESSION=file
SESSION_LIFETIME=7200
SESSION_SECURE=false

# Cache
CACHE=file

# E-mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_FROM_NAME="${APP_NAME}"

# Queue
# sync = executa imediatamente | file = fila assíncrona em storage/queue/
QUEUE=sync

# Log
# debug | info | notice | warning | error | critical | alert | emergency
LOG_LEVEL=debug

# Spark Inspector
SPARK_INSPECTOR=auto
SPARK_INSPECTOR_PREFIX=/_spark
SPARK_INSPECTOR_HISTORY=150
SPARK_INSPECTOR_MASK=false
SPARK_INSPECTOR_SLOW_MS=250
