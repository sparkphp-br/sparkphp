# Aplicação
APP_NAME=SparkPHP
# dev = erros detalhados, cache desabilitado | production = erros genéricos, cache ativo
APP_ENV=dev
APP_PORT=8000
APP_KEY=change-me-to-a-random-secret-32-chars
APP_LANG=pt-BR
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo

# Banco de dados
# mysql | pgsql | sqlite
DB=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sparkphp
DB_USER=root
DB_PASS=
# Para SQLite, basta: DB=sqlite (usa database/database.sqlite automaticamente)

# Sessão
# file
SESSION=file
SESSION_LIFETIME=7200
SESSION_SECURE=auto
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

# HTTP / proxies confiáveis
# Lista separada por vírgula (IP, CIDR ou *)
TRUSTED_PROXIES=

# CSRF / Request Forgery Protection
CSRF_REQUIRE_ORIGIN=false
CSRF_TRUSTED_ORIGINS=

# Cache
# file = persiste em disco | memory = só na requisição
CACHE=file

# E-mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# tls | ssl
MAIL_ENCRYPTION=tls
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_FROM_NAME="${APP_NAME}"

# Queue
# sync = executa imediatamente | file = fila assíncrona em storage/queue/
QUEUE=sync

# AI
# fake = driver local para desenvolvimento e testes
AI_DRIVER=fake
AI_TEXT_MODEL=spark-text
AI_EMBEDDING_MODEL=spark-embedding
AI_IMAGE_MODEL=spark-image
AI_IMAGE_SIZE=1024x1024
AI_AUDIO_MODEL=spark-audio
AI_AUDIO_VOICE=default
AI_AUDIO_FORMAT=mp3
AI_AGENT_MODEL=spark-agent
SPARK_AI_MASK=true
SPARK_AI_TRACE_PREVIEW=240

# Log
# debug | info | notice | warning | error | critical | alert | emergency
LOG_LEVEL=debug

# Spark Inspector
# auto = ativo em dev | on = sempre ativo | off = desabilitado
SPARK_INSPECTOR=auto
SPARK_INSPECTOR_PREFIX=/_spark
SPARK_INSPECTOR_HISTORY=150
SPARK_INSPECTOR_MASK=false
SPARK_INSPECTOR_SLOW_MS=250
