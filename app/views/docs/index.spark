<script>
    // Search filter
    const searchInput = document.getElementById('docs-search');
    if (searchInput) {
        searchInput.addEventListener('input', function () {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.docs-table-row').forEach(row => {
                const title = row.dataset.title || '';
                const desc = row.querySelector('.docs-table-row__desc')?.textContent?.toLowerCase() || '';
                row.style.display = (title.includes(query) || desc.includes(query)) ? '' : 'none';
            });
        });
    }

    function copyCode(btn) {
        const pre = btn.closest('.docs-code-window').querySelector('pre');
        navigator.clipboard.writeText(pre.textContent).then(() => {
            const orig = btn.textContent;
            btn.textContent = 'Copiado!';
            setTimeout(() => { btn.textContent = orig; }, 1500);
        });
    }
</script>
