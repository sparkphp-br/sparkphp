        <pre style="color:#e2e8f0;font-size:.9rem;margin:0;overflow:auto;"><?php echo htmlspecialchars(
'// app/routes/api/users.[id].php

get(fn(int $id) => User::find($id));

put(fn(int $id) => User::findOrFail($id)->update(input()));

delete(fn(int $id) => User::findOrFail($id)->delete());'
); ?></pre>
    </div>

