        . color('/' . (string) ($status['storage']['history_limit'] ?? 0), 'dim'));
    echo "\n";
}

function sparkMake(string $command, array $args): void
{
    $name = $args[0] ?? null;
    if (!$name) {
        out('  ' . color('Usage: ', 'dim') . color("php spark {$command} <Name>", 'white'));
        return;
    }

    $type = substr($command, 5); // strip "make:"

    $templates = [
        'model'     => [
            'path'    => "app/models/{$name}.php",
            'content' => "<?php\n\nclass {$name} extends Model\n{\n    //\n}\n",
        ],
        'middleware' => [
            'path'    => "app/middleware/{$name}.php",
            'content' => "<?php\n\n// Middleware: {$name}\n// Return a Response to block, or nothing to continue.\n",
        ],
        'migration' => [
            'path'    => "database/migrations/" . sparkNextMigrationPrefix() . "_{$name}.php",
            'content' => "<?php\n\n// Migration: {$name}\n\nup(function () {\n    db()->statement(\"\n        CREATE TABLE IF NOT EXISTS `table_name` (\n            `id` BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,\n            `created_at` DATETIME,\n            `updated_at` DATETIME\n        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4\n    \");\n});\n\ndown(function () {\n    db()->statement('DROP TABLE IF EXISTS `table_name`');\n});\n",
        ],
        'service'   => [
            'path'    => "app/services/{$name}.php",
            'content' => "<?php\n\nclass {$name}\n{\n    public function __construct()\n    {\n        //\n    }\n}\n",
        ],
        'job'       => [
            'path'    => "app/jobs/{$name}.php",
            'content' => "<?php\n\nclass {$name}\n{\n    public function __construct(private mixed \$data = null) {}\n\n    public function handle(): void\n    {\n        // Process the job\n    }\n}\n",
        ],
        'event'     => [
            'path'    => "app/events/{$name}.php",
            'content' => "<?php\n\n// Event: {$name}\n// \$data contains the dispatched payload.\n",
        ],
    ];

    if (!isset($templates[$type])) {
        error("Unknown make type: {$type}");
        return;
    }

    $tpl  = $templates[$type];
    $file = SPARK_BASE . '/' . $tpl['path'];
    $dir  = dirname($file);

    if (!is_dir($dir)) {
        mkdir($dir, 0755, true);
    }

    if (file_exists($file)) {
        out('  ' . color('Already exists: ', 'yellow') . color($tpl['path'], 'dim'));
        return;
    }

    file_put_contents($file, $tpl['content']);
    success('Created ' . color($tpl['path'], 'cyan'));
}

// ─── Queue commands ───────────────────────────────────────────────────────────

function sparkQueueWork(array $args): void
{
    require_once SPARK_BASE . '/core/Queue.php';

    $queue   = 'default';
    $sleep   = 3;
    $maxJobs = 0; // 0 = unlimited

    foreach ($args as $arg) {
        if (str_starts_with($arg, '--queue='))    $queue   = substr($arg, 8);
        if (str_starts_with($arg, '--sleep='))    $sleep   = (int)substr($arg, 8);
        if (str_starts_with($arg, '--max-jobs=')) $maxJobs = (int)substr($arg, 10);
    }

    $q       = new Queue(SPARK_BASE);
    $count   = 0;
    echo "\n";
    out(color('  ⚡ Queue worker started', 'cyan') . color(" [{$queue}]", 'green') . color(' — Ctrl+C to stop.', 'dim'));
    echo "\n";

    while (true) {
        $processed = $q->processNext($queue);

        if ($processed) {
            $count++;
            out('  ' . color(date('H:i:s'), 'dim') . ' ' . color("Job #{$count} processed", 'green'));
            if ($maxJobs > 0 && $count >= $maxJobs) {
                success("Max jobs reached ({$maxJobs}). Exiting.");
                break;
            }
        } else {
            sleep($sleep);
        }
    }
}

function sparkQueueClear(string $queue): void
{
    require_once SPARK_BASE . '/core/Queue.php';
    (new Queue(SPARK_BASE))->clear($queue);
    success("Queue [{$queue}] cleared.");
}

function sparkQueueList(): void
{
    require_once SPARK_BASE . '/core/Queue.php';
    $q = new Queue(SPARK_BASE);

    echo "\n";
    out('  ' . color(str_pad('Queue', 24), 'yellow') . color('Jobs', 'yellow'));
    out('  ' . color(str_repeat('─', 30), 'dim'));
    foreach ($q->queues() as $name) {
        $size = $q->size($name);
        $sizeColor = $size > 0 ? 'cyan' : 'dim';
        out('  ' . color(str_pad($name, 24), 'green') . color((string)$size, $sizeColor));
    }
    echo "\n";
}

function sparkNextMigrationPrefix(): string
{
    $dir   = SPARK_BASE . '/database/migrations';
    $files = is_dir($dir) ? glob($dir . '/*.php') : [];
    return str_pad((string)(count($files) + 1), 3, '0', STR_PAD_LEFT);
}

