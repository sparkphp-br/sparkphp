#!/usr/bin/env php
<?php

declare(strict_types=1);

define('SPARK_BASE', __DIR__);

require_once __DIR__ . '/core/Bootstrap.php';

// Minimal boot (no HTTP cycle)
$app = new Bootstrap(SPARK_BASE);
$app->boot();

// ─── CLI dispatcher ──────────────────────────────────────────────────────────

$args    = array_slice($argv, 1);
$command = $args[0] ?? 'help';
$rest    = array_slice($args, 1);

match (true) {
    // ── Project bootstrap ─────────────────────────────────────────────────────
    $command === 'init' => sparkInit($rest),

    // ── Server ────────────────────────────────────────────────────────────────
    $command === 'serve' => sparkServe($rest),

    // ── Benchmarks ────────────────────────────────────────────────────────────
    $command === 'benchmark' || $command === 'bench' => sparkBenchmark($rest),

    // ── Migrations ────────────────────────────────────────────────────────────
    $command === 'migrate'               => sparkMigrate(),
    $command === 'migrate:rollback'      => sparkMigrateRollback((int)($rest[0] ?? 1)),
    $command === 'migrate:fresh'         => sparkMigrateFresh(),
    $command === 'migrate:status'        => sparkMigrateStatus(),

    // ── Seeds ─────────────────────────────────────────────────────────────────
    $command === 'seed'  => sparkSeed($rest[0] ?? null),

    // ── Queue ─────────────────────────────────────────────────────────────────
    $command === 'queue:work'   => sparkQueueWork($rest),
    $command === 'queue:clear'  => sparkQueueClear($rest[0] ?? 'default'),
    $command === 'queue:list'   => sparkQueueList(),

    // ── Cache ─────────────────────────────────────────────────────────────────
    $command === 'cache:clear'     => sparkCacheClear(),
    $command === 'views:cache'     => sparkViewsCache(),
    $command === 'views:clear'     => sparkViewsClear(),
    $command === 'routes:cache'    => sparkRoutesCache(),
    $command === 'routes:clear'    => sparkRoutesClear(),
    $command === 'routes:list'     => sparkRoutesList(),
    $command === 'inspector:clear' => sparkInspectorClear(),
    $command === 'inspector:status' => sparkInspectorStatus(),
    $command === 'optimize'        => sparkOptimize(),

    // ── Make ──────────────────────────────────────────────────────────────────
    str_starts_with($command, 'make:') => sparkMake($command, $rest),

    // ── Help ──────────────────────────────────────────────────────────────────
    default => sparkHelp(),
};

// ─────────────────────────────────────────────────────────────────────────────
// Commands
// ─────────────────────────────────────────────────────────────────────────────

function sparkServe(array $args): void
{
    $port = 8000;
    foreach ($args as $arg) {
        if (str_starts_with($arg, '--port=')) {
            $port = (int) substr($arg, 7);
        }
    }
    $host = '0.0.0.0';
    echo "\n";
    out(color('  ⚡ SparkPHP', 'cyan') . color(" server running at ", 'dim') . color("http://localhost:{$port}", 'green'));
    out(color("     Press Ctrl+C to stop.", 'dim'));
    echo "\n";
    passthru("php -S {$host}:{$port} " . SPARK_BASE . '/public/index.php');
}

function sparkBenchmark(array $args): void
{
    require_once SPARK_BASE . '/core/BenchmarkRunner.php';

    $iterations = 200;
    $warmup = 15;
    $json = in_array('--json', $args, true);
    $save = SPARK_BASE . '/storage/benchmarks/latest.json';
    $noSave = in_array('--no-save', $args, true);

    foreach ($args as $arg) {
        if (str_starts_with($arg, '--iterations=')) {
            $iterations = max(1, (int) substr($arg, 13));
        }

        if (str_starts_with($arg, '--warmup=')) {
            $warmup = max(0, (int) substr($arg, 9));
        }

        if (str_starts_with($arg, '--save=')) {
            $save = SPARK_BASE . '/' . ltrim(substr($arg, 7), '/');
        }
    }

    $runner = new BenchmarkRunner(SPARK_BASE);
    $report = $runner->run($iterations, $warmup);

    if (!$noSave) {
        $savedPath = $runner->save($report, $save);
        $report['saved_to'] = $savedPath;
    }

    if ($json) {
        echo json_encode($report, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . PHP_EOL;
        return;
    }

    sparkRenderBenchmarkReport($report, !$noSave);
}

function sparkInit(array $args): void
{
    require_once SPARK_BASE . '/core/ProjectScaffolder.php';

    $force = in_array('--force', $args, true);
    $quiet = in_array('--quiet', $args, true);

    $scaffolder = new ProjectScaffolder(SPARK_BASE);
    $result = $scaffolder->initialize($force);

    if ($quiet) {
        return;
    }

    echo "\n";
    out(color('  ⚡ SparkPHP', 'cyan') . color(' project bootstrap', 'dim'));
    foreach ($result['messages'] as $message) {
        out('  ' . color('• ', 'dim') . $message);
    }
    echo "\n";

    success('Project is ready.');
}

// ─── Migration state ─────────────────────────────────────────────────────────
// Tracked in storage/migrations.json as:
// [{"batch": 1, "file": "001_create_users.php", "ran_at": "..."}]
//
// Migration files define up() and down() functions via capture vars:
//   up(fn() => db()->statement("CREATE TABLE ..."));
//   down(fn() => db()->statement("DROP TABLE ..."));

function sparkMigrationStatePath(): string
{
    return SPARK_BASE . '/storage/migrations.json';
}

function sparkMigrationState(): array
{
    $file = sparkMigrationStatePath();
    return file_exists($file) ? (json_decode((string)file_get_contents($file), true) ?? []) : [];
}

function sparkMigrationSave(array $state): void
{
    $dir = dirname(sparkMigrationStatePath());
    if (!is_dir($dir)) mkdir($dir, 0755, true);
    file_put_contents(sparkMigrationStatePath(), json_encode($state, JSON_PRETTY_PRINT));
}

function sparkRunMigrationFile(string $file, string $direction = 'up'): void
{
    // Provide up()/down() capture functions
    $captured = [];
    $up   = function (callable $fn) use (&$captured) { $captured['up']   = $fn; };
    $down = function (callable $fn) use (&$captured) { $captured['down'] = $fn; };

    (static function () use ($file, $up, $down) { require $file; })();

    if (!isset($captured[$direction])) {
        // Legacy migration: just required the file (runs on include). Already done above.
        return;
    }
    ($captured[$direction])();
}

function sparkMigrate(): void
{
    $dir = SPARK_BASE . '/database/migrations';
    if (!is_dir($dir)) {
        out(color('  No migrations directory found.', 'yellow'));
        return;
    }

    $files = glob($dir . '/*.php');
    sort($files);

    $state   = sparkMigrationState();
    $ran     = array_column($state, 'file');
    $batch   = $state ? (max(array_column($state, 'batch')) + 1) : 1;
    $pending = array_filter($files, fn($f) => !in_array(basename($f), $ran, true));

    if (empty($pending)) {
        out(color('  Nothing to migrate.', 'dim'));
        return;
    }

    require_once SPARK_BASE . '/core/Database.php';

    foreach ($pending as $file) {
        $name = basename($file);
        out('  ' . color('Migrating ', 'dim') . color($name, 'cyan'));
        sparkRunMigrationFile($file, 'up');
        $state[] = ['batch' => $batch, 'file' => $name, 'ran_at' => date('Y-m-d H:i:s')];
    }

    sparkMigrationSave($state);
    success("Batch {$batch} — " . count($pending) . " migration(s) complete.");
}

function sparkMigrateRollback(int $batches = 1): void
{
    $dir   = SPARK_BASE . '/database/migrations';
    $state = sparkMigrationState();

    if (empty($state)) {
        out(color('  Nothing to rollback.', 'dim'));
        return;
    }

    require_once SPARK_BASE . '/core/Database.php';

    $maxBatch  = max(array_column($state, 'batch'));
    $minBatch  = max(1, $maxBatch - $batches + 1);
    $toRollback = array_filter($state, fn($r) => $r['batch'] >= $minBatch);
    $toRollback = array_reverse(array_values($toRollback));

    foreach ($toRollback as $record) {
        $file = $dir . '/' . $record['file'];
        out('  ' . color('Rolling back ', 'dim') . color($record['file'], 'yellow'));
        if (file_exists($file)) {
            sparkRunMigrationFile($file, 'down');
        } else {
            out('  ' . color('Warning: file not found, skipping.', 'red'));
        }
    }

    $remaining = array_filter($state, fn($r) => $r['batch'] < $minBatch);
    sparkMigrationSave(array_values($remaining));
    success('Rolled back ' . count($toRollback) . ' migration(s).');
}

function sparkMigrateFresh(): void
{
    out(color('  Rolling back all migrations...', 'yellow'));
    $state = sparkMigrationState();
    if (!empty($state)) {
        $batches = max(array_column($state, 'batch'));
        sparkMigrateRollback($batches);
    }
    out(color('  Re-running all migrations...', 'cyan'));
    sparkMigrate();
}

function sparkMigrateStatus(): void
{
    $state = sparkMigrationState();
    $dir   = SPARK_BASE . '/database/migrations';
    $files = is_dir($dir) ? glob($dir . '/*.php') : [];
    sort($files);
    $ran   = array_column($state, null, 'file');

    echo "\n";
    out('  ' . color(str_pad('Status', 14), 'yellow') . color(str_pad('Batch', 8), 'yellow') . color(str_pad('File', 50), 'yellow') . color('Ran At', 'yellow'));
    out('  ' . color(str_repeat('─', 88), 'dim'));

    foreach ($files as $file) {
        $name   = basename($file);
        $record = $ran[$name] ?? null;
        $status = $record ? color(str_pad('Ran', 14), 'green') : color(str_pad('Pending', 14), 'yellow');
        $batch  = str_pad((string)($record['batch'] ?? '—'), 8);
        $ranAt  = $record['ran_at'] ?? '—';
        out('  ' . $status . color($batch, 'dim') . str_pad($name, 50) . color($ranAt, 'dim'));
    }
    echo "\n";
}

function sparkSeed(?string $seeder = null): void
{
    $dir = SPARK_BASE . '/database/seeds';
    if ($seeder) {
        $file = $dir . "/{$seeder}.php";
        if (!file_exists($file)) {
            error("Seeder not found: {$seeder}");
            return;
        }
        require $file;
        success("{$seeder} executed.");
        return;
    }

    foreach (glob($dir . '/*.php') as $file) {
        out('  ' . color('Seeding ', 'dim') . color(basename($file), 'cyan'));
        require $file;
    }
    success('All seeders executed.');
}

function sparkCacheClear(): void
{
    $dirs = [
        SPARK_BASE . '/storage/cache/env.php',
        SPARK_BASE . '/storage/cache/classes.php',
        SPARK_BASE . '/storage/cache/routes.php',
    ];
    foreach ($dirs as $path) {
        if (file_exists($path)) {
            unlink($path);
            out('  ' . color('Cleared ', 'dim') . color(basename($path), 'cyan'));
        }
    }

    // Clear app cache files
    foreach (glob(SPARK_BASE . '/storage/cache/app/*.cache') as $f) {
        unlink($f);
    }
    success('Cache cleared.');
}

function sparkViewsCache(): void
{
    require_once SPARK_BASE . '/core/View.php';
    $view    = new View(SPARK_BASE);
    $viewDir = SPARK_BASE . '/app/views';
    $count   = 0;

    foreach (new RecursiveIteratorIterator(new RecursiveDirectoryIterator($viewDir, FilesystemIterator::SKIP_DOTS)) as $file) {
        if ($file->getExtension() === 'spark') {
            $rel = str_replace([$viewDir . '/', $viewDir . '\\', '.spark'], ['', '', ''], $file->getPathname());
            try {
                $view->render($rel, []);
                $count++;
            } catch (\Throwable $e) {
                out('  ' . color("Warning [{$rel}]: " . $e->getMessage(), 'yellow'));
            }
        }
    }
    success("{$count} views cached.");
}

function sparkViewsClear(): void
{
    foreach (glob(SPARK_BASE . '/storage/cache/views/*.php') as $f) {
        unlink($f);
    }
    success('View cache cleared.');
}

function sparkRoutesCache(): void
{
    require_once SPARK_BASE . '/core/Router.php';
    $router = new Router(SPARK_BASE);
    $routes = $router->buildRoutes();
    success(count($routes) . ' routes cached.');
}

function sparkRoutesClear(): void
{
    $file = SPARK_BASE . '/storage/cache/routes.php';
    if (file_exists($file)) {
        unlink($file);
    }
    success('Route cache cleared.');
}

function sparkRoutesList(): void
{
    require_once SPARK_BASE . '/core/Router.php';
    $router = new Router(SPARK_BASE);
    $routes = $router->list();

    echo "\n";
    out('  ' . color(str_pad('URL', 40), 'yellow') . color(str_pad('Middlewares', 30), 'yellow') . color('File', 'yellow'));
    out('  ' . color(str_repeat('─', 88), 'dim'));

    foreach ($routes as $route) {
        $mwRaw = implode(', ', $route['middlewares']);
        $mw    = $mwRaw ?: '—';
        $file  = str_replace(SPARK_BASE . '/app/routes/', '', $route['file']);
        $mwPad = str_pad($mw, 30);
        $mwStr = $mwRaw ? color($mwPad, 'cyan') : color($mwPad, 'dim');
        out('  ' . color(str_pad($route['url'], 40), 'green') . $mwStr . color($file, 'dim'));
    }
    echo "\n";
}

function sparkOptimize(): void
{
    sparkCacheClear();
    sparkRoutesCache();
    sparkViewsCache();
    success('Application optimized for production.');
}

