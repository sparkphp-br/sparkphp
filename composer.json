{
    "name": "sparkphp/sparkphp",
    "description": "SparkPHP — Write what matters.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "serve": "php spark serve",
        "test": "vendor/bin/phpunit",
        "bench": "php spark benchmark",
        "post-create-project-cmd": [
            "@php spark init --quiet"
        ]
    },
    "minimum-stability": "stable"
}
